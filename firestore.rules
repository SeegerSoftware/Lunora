rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // REGLES DEV TEMPORAIRES : tout utilisateur authentifie peut lire/ecrire.
    // Objectif: debloquer rapidement les erreurs permission-denied.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
