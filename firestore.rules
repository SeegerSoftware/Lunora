rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // isAdmin : réservé à la console Firebase / backend — le client ne peut pas le modifier.
      allow create: if request.auth != null && request.auth.uid == userId &&
        (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false);
      allow update: if request.auth != null && request.auth.uid == userId &&
        (!('isAdmin' in request.resource.data) ||
          request.resource.data.isAdmin == resource.data.get('isAdmin', false));
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /subscriptions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /children_profiles/{profileId} {
      allow read: if request.auth != null && (
        !exists(/databases/$(database)/documents/children_profiles/$(profileId)) ||
        resource.data.userId == request.auth.uid
      );
      // set(merge: true) = create if missing, else update
      allow create, update: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        (
          !exists(/databases/$(database)/documents/children_profiles/$(profileId)) ||
          !resource.data.keys().hasAll(['userId']) ||
          resource.data.userId == request.auth.uid
        );
      allow delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    match /child_series_state/{childId} {
      allow read: if request.auth != null && (
        !exists(/databases/$(database)/documents/child_series_state/$(childId)) ||
        resource.data.userId == request.auth.uid
      );
      allow create, update: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      // Suppression quand passage en « une histoire par jour » : le doc série peut
      // être ancien sans champ userId ; on s’aligne sur le profil enfant (même id).
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (
          exists(/databases/$(database)/documents/children_profiles/$(childId)) &&
          get(/databases/$(database)/documents/children_profiles/$(childId)).data.userId ==
            request.auth.uid
        )
      );
    }

    match /stories/{storyId} {
      allow read: if request.auth != null && (
        !exists(/databases/$(database)/documents/stories/$(storyId)) ||
        resource.data.userId == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    match /story_worlds/{childId} {
      allow read: if request.auth != null && (
        !exists(/databases/$(database)/documents/story_worlds/$(childId)) ||
        resource.data.userId == request.auth.uid
      );
      allow create, update: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        exists(/databases/$(database)/documents/children_profiles/$(childId)) &&
        get(/databases/$(database)/documents/children_profiles/$(childId)).data.userId ==
          request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    match /story_memory_snapshots/{snapshotId} {
      allow read: if request.auth != null && (
        !exists(/databases/$(database)/documents/story_memory_snapshots/$(snapshotId)) ||
        resource.data.userId == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }
  }
}
