rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerByUid(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function ownerMatchesUserIdOnCreate() {
      return isSignedIn() &&
          request.resource.data.userId is string &&
          request.resource.data.userId == request.auth.uid;
    }

    function ownerMatchesUserId() {
      return isSignedIn() &&
          resource.data.userId is string &&
          resource.data.userId == request.auth.uid;
    }

    function ownerMatchesOnWrite() {
      return ownerMatchesUserIdOnCreate() &&
          (!('userId' in resource.data) || resource.data.userId == request.auth.uid);
    }

    // Profil utilisateur principal.
    match /users/{userId} {
      allow read: if isOwnerByUid(userId);
      allow create: if isOwnerByUid(userId) &&
          request.resource.data.id == request.auth.uid;
      allow update, delete: if isOwnerByUid(userId);
    }

    // Donnees enfant (1 profil par enfant).
    match /children_profiles/{childId} {
      allow read: if ownerMatchesUserId();
      allow create: if ownerMatchesUserIdOnCreate();
      allow update: if ownerMatchesOnWrite();
      allow delete: if ownerMatchesUserId();
    }

    // Histoires generees.
    match /stories/{storyId} {
      allow read: if ownerMatchesUserId();
      allow create: if ownerMatchesUserIdOnCreate();
      allow update: if ownerMatchesOnWrite();
      allow delete: if ownerMatchesUserId();
    }

    // Etat des series par enfant.
    match /child_series_state/{childId} {
      allow read: if ownerMatchesUserId();
      allow create: if ownerMatchesUserIdOnCreate();
      allow update: if ownerMatchesOnWrite();
      allow delete: if ownerMatchesUserId();
    }

    // Abonnement utilisateur.
    match /subscriptions/{userId} {
      allow read: if isOwnerByUid(userId);
      allow create: if isOwnerByUid(userId) &&
          request.resource.data.userId == request.auth.uid;
      allow update: if isOwnerByUid(userId) &&
          request.resource.data.userId == request.auth.uid;
      allow delete: if isOwnerByUid(userId);
    }

    // Memoire narrative long terme.
    match /story_worlds/{worldId} {
      allow read: if ownerMatchesUserId();
      allow create: if ownerMatchesUserIdOnCreate();
      allow update: if ownerMatchesOnWrite();
      allow delete: if ownerMatchesUserId();
    }

    // Snapshots de memoire par histoire.
    match /story_memory_snapshots/{snapshotId} {
      allow read: if ownerMatchesUserId();
      allow create: if ownerMatchesUserIdOnCreate();
      allow update: if ownerMatchesOnWrite();
      allow delete: if ownerMatchesUserId();
    }
  }
}
